# ── Olimlar.uz environment template ─────────────────────────────────────────
# Copy to .env and fill in real values:  cp .env.example .env
# .env is gitignored and must NEVER be committed.

# ── REQUIRED ────────────────────────────────────────────────────────────────

# Neon PostgreSQL connection string. Keep sslmode=require for the public
# endpoint (the app also auto-appends it for remote hosts if omitted).
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# Flask session / CSRF secret. Generate a strong random value:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=replace-with-64-hex-chars

# ── OPTIONAL (features degrade gracefully if unset) ─────────────────────────

# Alternative DB var name, used only if DATABASE_URL is empty.
# POSTGRES_URL=

# AI assistant / analytics helpers.
GROQ_API_KEY=
GEMINI_API_KEY=
OAK_API_KEY=

# OpenAlex (maqolalar tahlili) — API kalit KERAK EMAS. mailto bilan "polite
# pool" (tezroq, barqaror javob) ishlaydi; istalgan haqiqiy email bo'ladi.
OPENALEX_MAILTO=info@olimlar.uz

# Google OAuth login (cabinet). Redirect URI must be registered in Google Cloud.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://www.olimlar.uz/auth/google/callback

# Telegram login widget / bot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=send_kod_bot

# Scraper → site ingest API (GitHub Action secrets).
SITE_API_URL=
SITE_API_KEY=

# Smart Eslatmalar cron auth — X-API-Key for POST /api/v1/reminders/process
# (also set as the REMINDERS_API_KEY GitHub Action secret).
REMINDERS_API_KEY=

# ── ATMOS to'lov tizimi (blueprints/payments.py) ────────────────────────────
# Merchant kabinetidan olinadi. TEST rejimda test-checkout ishlatiladi.
ATMOS_CONSUMER_KEY=
ATMOS_CONSUMER_SECRET=
ATMOS_STORE_ID=
# Callback imzosini tekshirish kaliti (kabinetda "api_key" deb beriladi).
ATMOS_API_KEY=
# API bazasi (docs.atmos.uz bo'yicha standart qiymat).
ATMOS_API_BASE=https://apigw.atmos.uz
# true — sandbox: checkout test-checkout.pays.uz ga boradi; ATMOS hisob
# ma'lumotlari bo'sh bo'lsa lokal simulyatsiya rejimi yoqiladi.
ATMOS_TEST_MODE=false
# Callback sign hash algoritmi (md5|sha1|sha256) — ATMOS integratsiyasida
# aniqlashtiriladi; standart md5.
# ATMOS_CALLBACK_ALGO=md5
# Checkout bazasini majburan almashtirish (odatda kerak emas).
# ATMOS_CHECKOUT_BASE=https://checkout.pays.uz

# Port the app binds to. Leave unset on Cloud Run/App Engine (platform injects
# PORT); the container defaults to 8000 for the nginx-fronted VPS setup.
# PORT=8000
