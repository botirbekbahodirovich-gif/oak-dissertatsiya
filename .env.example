# ── Olimlar.uz environment template ─────────────────────────────────────────
# Copy to .env and fill in real values:  cp .env.example .env
# .env is gitignored and must NEVER be committed.

# ── REQUIRED ────────────────────────────────────────────────────────────────

# Neon PostgreSQL connection string. Keep sslmode=require for the public
# endpoint (the app also auto-appends it for remote hosts if omitted).
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# Flask session / CSRF secret. Generate a strong random value:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=replace-with-64-hex-chars

# ── OPTIONAL (features degrade gracefully if unset) ─────────────────────────

# Alternative DB var name, used only if DATABASE_URL is empty.
# POSTGRES_URL=

# AI assistant / analytics helpers.
GROQ_API_KEY=
GEMINI_API_KEY=
OAK_API_KEY=

# Google OAuth login (cabinet). Redirect URI must be registered in Google Cloud.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://www.olimlar.uz/auth/google/callback

# Telegram login widget / bot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=send_kod_bot

# Scraper → site ingest API (GitHub Action secrets).
SITE_API_URL=
SITE_API_KEY=

# Port the app binds to. Leave unset on Cloud Run/App Engine (platform injects
# PORT); the container defaults to 8000 for the nginx-fronted VPS setup.
# PORT=8000
